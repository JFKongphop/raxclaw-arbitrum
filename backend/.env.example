# ════════════════════════════════════════════════════════════════════════════════
# RAXC Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════════

# ─── OpenAI (LLM + Embeddings) ──────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini       # or gpt-4o

# ─── Qdrant Vector Database ────────────────────────────────────────────────────
# Create a free cluster at: https://cloud.qdrant.io
QDRANT_ENDPOINT=https://xxx.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ─── Arbitrum Sepolia (Stylus Contracts) ───────────────────────────────────────
# Public RPC (free): https://sepolia-rollup.arbitrum.io/rpc
# Or use Infura/Alchemy for production reliability
ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
PRIVATE_KEY=0x...              # Wallet private key (needs Sepolia ETH for gas)
AGENT_MEMORY=0x...             # Deployed AgentMemory Stylus contract address
AUDIT_REPORT=0x...             # Deployed AuditReport Stylus contract address
AGENT_TOKEN_ID=0               # Optional token ID for multi-agent setups

# ─── WebSocket ─────────────────────────────────────────────────────────────────
WS_PORT=3001                   # Server port
